---
import categories from '../../data/categories.yaml';

const { active } = Astro.props as { active?: string };
---

<nav class="space-y-1">
  <a href="/trey-tools/"
     class={`block px-3 py-2 rounded-lg text-sm transition-colors ${!active ? 'bg-zinc-800 text-white' : 'text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/50'}`}>
    🏠 全部工具
  </a>
  {categories.categories.map((cat: any) => (
    <a href={`/trey-tools/category/${cat.slug}`}
       class={`block px-3 py-2 rounded-lg text-sm transition-colors ${active === cat.slug ? 'bg-zinc-800 text-white' : 'text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800/50'}`}>
      {cat.name}
    </a>
  ))}
</nav>
