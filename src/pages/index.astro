---
import Base from '../layouts/Base.astro';
import ToolCard from '../components/ToolCard.astro';
import CategoryNav from '../components/CategoryNav.astro';
import { getAllTools, getFeaturedTools, getDiscoveredTools, filterByTags } from '../lib/tools';

const allTools = getAllTools();
const featured = getFeaturedTools();
const trending = allTools.filter(t => t.source === 'daily' || t.source === 'weekly').slice(0, 6);
const discovered = getDiscoveredTools().filter(t => t.source !== 'daily' && t.source !== 'weekly');
const tagParam = Astro.url.searchParams.get('tags') || '';
const selectedTags = tagParam ? tagParam.split(',').filter(Boolean) : [];
const filtered = selectedTags.length ? filterByTags(allTools, selectedTags) : allTools;
---

<Base>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-3xl font-bold mb-2">🛠️ trey-tools</h1>
      <p class="text-zinc-400">开源工具导航站 — 发现好用的开源工具，以 AI 为主但不设限</p>
      <p class="text-sm text-zinc-600 mt-1">
        已收录 <span class="text-zinc-300 font-mono">{allTools.length}</span> 个工具
      </p>
    </header>

    <div class="flex gap-8">
      <!-- Sidebar -->
      <aside class="w-48 shrink-0 hidden lg:block">
        <CategoryNav />
      </aside>

      <!-- Main -->
      <main class="flex-1 min-w-0">
        <!-- Featured -->
        {featured.length > 0 && (
          <section class="mb-10">
            <h2 class="text-lg font-semibold mb-4 text-amber-400">⭐ 精选推荐</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
              {featured.map(tool => <ToolCard {...tool} />)}
            </div>
          </section>
        )}

        <!-- Trending -->
        {trending.length > 0 && (
          <section class="mb-10">
            <h2 class="text-lg font-semibold mb-4 text-red-400">🔥 今日趋势</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
              {trending.map(tool => <ToolCard {...tool} />)}
            </div>
          </section>
        )}

        <!-- Discovered -->
        {discovered.length > 0 && (
          <section class="mb-10">
            <h2 class="text-lg font-semibold mb-4 text-zinc-300">🤖 最新发现</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
              {discovered.slice(0, 6).map(tool => <ToolCard {...tool} />)}
            </div>
          </section>
        )}

        <!-- All tools -->
        <section>
          <h2 class="text-lg font-semibold mb-4 text-zinc-300">
            {selectedTags.length ? `筛选结果 (${filtered.length})` : '全部工具'}
          </h2>
          {selectedTags.length > 0 && (
            <p class="text-sm text-zinc-500 mb-3">
              标签：{selectedTags.join(', ')} · <a href="/trey-tools/" class="text-blue-400 hover:underline">清除筛选</a>
            </p>
          )}
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
            {filtered.map(tool => <ToolCard {...tool} />)}
          </div>
        </section>
      </main>
    </div>
  </div>
</Base>
