---
import Base from '../../layouts/Base.astro';
import ToolCard from '../../components/ToolCard.astro';
import CategoryNav from '../../components/CategoryNav.astro';
import TagFilter from '../../components/TagFilter.astro';
import { getToolsByCategory, filterByTags } from '../../lib/tools';
import categories from '../../../data/categories.yaml';

export function getStaticPaths() {
  return categories.categories.map((cat: any) => ({
    params: { slug: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;
const tagParam = Astro.url.searchParams.get('tags') || '';
const selectedTags = tagParam ? tagParam.split(',').filter(Boolean) : [];
let tools = getToolsByCategory(category.slug);
tools = selectedTags.length ? filterByTags(tools, selectedTags) : tools;
---

<Base>
  <div class="max-w-7xl mx-auto px-4 py-8">
    <header class="mb-6">
      <a href="/trey-tools/" class="text-sm text-zinc-500 hover:text-zinc-300 mb-2 inline-block">← 返回首页</a>
      <h1 class="text-2xl font-bold">{category.name}</h1>
      <p class="text-zinc-500 text-sm mt-1">{category.description} · {tools.length} 个工具</p>
    </header>

    <div class="flex gap-8">
      <aside class="w-48 shrink-0 hidden lg:block">
        <CategoryNav active={category.slug} />
      </aside>

      <main class="flex-1 min-w-0">
        <div class="mb-6">
          <TagFilter selected={selectedTags} />
        </div>

        {tools.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
            {tools.map(tool => <ToolCard {...tool} />)}
          </div>
        ) : (
          <p class="text-zinc-500 py-12 text-center">该分类下暂无工具。{selectedTags.length ? ' 试试去掉标签筛选？' : ''}</p>
        )}
      </main>
    </div>
  </div>
</Base>
